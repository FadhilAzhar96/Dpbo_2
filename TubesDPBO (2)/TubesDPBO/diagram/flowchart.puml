@startuml Flowchart
!pragma layout smetana
skinparam dpi 130
skinparam defaultFontName Arial
skinparam ActivityBackgroundColor #EAF2FB
skinparam ActivityBorderColor #2C3E50
skinparam ArrowColor #2C3E50

start
:Inisialisasi sistem;
:Login sebagai AdminPetugas
(tampilkan peran "Admin");
repeat :Tampilkan Menu Utama;
  :Baca pilihan menu (bacaInt);
  switch (Pilihan ?)
  case (1)
    :Input data calon
(validasi nama & nilai 0-100);
    :Hitung total & tentukan
status (Lulus/Tidak Lulus);
    :Simpan ke ArsipPendaftaranCalon;
  case (2)
    :Tampilkan semua calon (tabel);
  case (3)
    :Cari calon berdasarkan nama;
  case (4)
    :Ubah nilai tes & evaluasi ulang;
  case (5)
    :Hapus calon berdasarkan nama;
  case (6)
    :Tampilkan calon nilai tertinggi;
  case (7)
    :Tampilkan ringkasan statistik;
  case (lainnya)
    :Tampilkan pesan
"menu tidak tersedia";
  endswitch
repeat while (Pilihan != 0 ?) is (ya)
->tidak;
:Tampilkan pesan terima kasih;
stop
@enduml
